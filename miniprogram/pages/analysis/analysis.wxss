.analysis-page { padding-top: 18rpx; }
.analysis-metrics { margin-bottom: 8rpx; }
.bar-row { display: flex; align-items: center; margin-bottom: 16rpx; }
.bar-label { width: 130rpx; color: #667085; font-size: 22rpx; }
.bar-track { flex: 1; height: 18rpx; background: #EEF1F5; border-radius: 999rpx; overflow: hidden; }
.bar-fill { height: 100%; background: #FF5A1F; border-radius: 999rpx; }
.bar-value { width: 86rpx; text-align: right; color: #111827; font-size: 22rpx; font-weight: 700; }
