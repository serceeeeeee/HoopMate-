.range-row { display: flex; gap: 14rpx; margin-top: 24rpx; }
.range-chip { flex: 1; text-align: center; padding: 16rpx 0; border-radius: 999rpx; color: #94A3B8; background: rgba(255,255,255,.055); font-size: 24rpx; border: 1rpx solid rgba(255,255,255,.07); }
.range-chip.active { color: #FDBA74; background: rgba(255,122,26,.15); border-color: rgba(255,122,26,.3); }
.chart-card { overflow: hidden; }
.trend-scroll, .bar-scroll { white-space: nowrap; }
.trend-line-wrap { min-width: 720rpx; height: 320rpx; display: flex; align-items: flex-end; gap: 18rpx; padding: 26rpx 0 20rpx; border-bottom: 1rpx solid rgba(255,255,255,.08); }
.trend-node { position: relative; width: 84rpx; height: 280rpx; display: inline-block; }
.node-line { position: absolute; left: 40rpx; bottom: 44rpx; width: 4rpx; background: linear-gradient(180deg, #FF7A1A, #22D3EE); border-radius: 999rpx; }
.node-dot { position: absolute; left: 28rpx; width: 28rpx; height: 28rpx; margin-bottom: 34rpx; border-radius: 50%; background: #FF7A1A; box-shadow: 0 0 20rpx rgba(255,122,26,.75); }
.node-rate { position: absolute; top: 0; left: 0; right: 0; text-align: center; font-size: 22rpx; color: #CBD5E1; }
.node-date { position: absolute; bottom: 0; left: 0; right: 0; text-align: center; font-size: 21rpx; color: #64748B; }
.bar-wrap { min-width: 720rpx; height: 320rpx; display: flex; align-items: flex-end; gap: 20rpx; padding-top: 26rpx; border-bottom: 1rpx solid rgba(255,255,255,.08); }
.bar-item { position: relative; width: 72rpx; height: 280rpx; display: inline-flex; align-items: flex-end; justify-content: center; }
.bar { width: 42rpx; min-height: 22rpx; border-radius: 999rpx 999rpx 8rpx 8rpx; background: linear-gradient(180deg, #22D3EE, #1D4ED8); box-shadow: 0 0 24rpx rgba(34,211,238,.18); margin-bottom: 42rpx; }
.bar-value { position: absolute; top: 0; left: 0; right: 0; text-align: center; font-size: 22rpx; color: #CBD5E1; }
.analysis-row { margin-bottom: 24rpx; color: #CBD5E1; font-size: 25rpx; }
.court-visual { position: relative; height: 360rpx; border-radius: 28rpx; border: 3rpx solid rgba(255,255,255,.11); overflow: hidden; margin-bottom: 26rpx; background: radial-gradient(circle at 50% 18%, rgba(255,122,26,.15), transparent 36%), rgba(15,23,42,.78); }
.court-line { position: absolute; left: 50%; transform: translateX(-50%); border: 3rpx solid rgba(255,255,255,.14); }
.arc { width: 540rpx; height: 540rpx; border-radius: 50%; top: 84rpx; }
.paint { width: 220rpx; height: 190rpx; top: 0; border-top: 0; border-radius: 0 0 24rpx 24rpx; }
.rim { position: absolute; top: 70rpx; left: 50%; transform: translateX(-50%); width: 72rpx; height: 18rpx; border: 4rpx solid #FF7A1A; border-radius: 50%; }
.zone-label { position: absolute; padding: 8rpx 12rpx; border-radius: 999rpx; background: rgba(255,122,26,.17); color: #FDBA74; font-size: 22rpx; }
.zone-0 { top: 110rpx; left: 278rpx; }
.zone-1 { top: 172rpx; left: 300rpx; }
.zone-2 { top: 230rpx; left: 90rpx; }
.zone-3 { top: 230rpx; right: 90rpx; }
.conclusion-text { font-size: 28rpx; line-height: 1.7; color: #E2E8F0; margin-bottom: 24rpx; }
