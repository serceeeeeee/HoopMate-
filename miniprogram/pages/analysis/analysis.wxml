<view class="hm-page with-tab analysis-page">
  <view class="wrap-row analysis-metrics">
    <view class="col-2"><view class="metric-box analysis-metric"><view class="metric-label">总命中率</view><view class="metric-value orange">{{summary.avg_shooting_rate}}<text class="metric-unit">%</text></view><view class="metric-sub">{{summary.made_shots}}/{{summary.total_shots}}</view></view></view>
    <view class="col-2"><view class="metric-box analysis-metric"><view class="metric-label">禁区</view><view class="metric-value">{{summary.paint_rate}}<text class="metric-unit">%</text></view><view class="metric-sub">近框终结</view></view></view>
    <view class="col-2"><view class="metric-box analysis-metric"><view class="metric-label">中距离</view><view class="metric-value">{{summary.mid_rate}}<text class="metric-unit">%</text></view><view class="metric-sub">节奏稳定性</view></view></view>
    <view class="col-2"><view class="metric-box analysis-metric"><view class="metric-label">三分</view><view class="metric-value">{{summary.three_rate}}<text class="metric-unit">%</text></view><view class="metric-sub">外线效率</view></view></view>
  </view>

  <court-heatmap-canvas
    zones="{{zones}}"
    summary="{{heatmapSummary}}"
    title="投篮热区图"
    subtitle="颜色越深代表命中率越高，浅灰代表无出手区域"
    tag="命中率"
    height-rpx="500"
    show-legend="{{true}}"
    interactive="{{true}}"
    bindzonechange="onHeatmapZoneChange"
  ></court-heatmap-canvas>

  <view class="hm-card">
    <view class="section-header"><view><view class="section-title">投篮点位图</view><view class="section-subtitle">橙色圆点表示命中，灰色叉号表示未命中</view></view></view>
    <view class="court">
      <view class="court-line paint-line"></view><view class="court-line ft-line"></view><view class="court-line arc-line"></view><view class="court-line hoop-line"></view>
      <view wx:for="{{points}}" wx:key="id" class="shot-point {{item.made ? '' : 'miss'}}" style="left: {{item.x}}%; top: {{item.y}}%;">{{item.made ? '' : '×'}}</view>
    </view>
  </view>

  <view class="hm-card">
    <view class="section-header"><view><view class="section-title">命中率趋势</view><view class="section-subtitle">最近 10 次训练命中率变化</view></view></view>
    <view class="trend-card">
      <view wx:for="{{trend}}" wx:key="label" class="trend-col">
        <view class="trend-bar" style="height: {{item.height}}%;"></view>
        <view class="trend-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="hm-card">
    <view class="section-header"><view><view class="section-title">项目分析</view><view class="section-subtitle">按训练时长统计不同训练类型占比</view></view></view>
    <view wx:for="{{categories}}" wx:key="name" class="bar-row">
      <view class="bar-label">{{item.name}}</view><view class="bar-track"><view class="bar-fill" style="width: {{item.percent}}%;"></view></view><view class="bar-value">{{item.percent}}%</view>
    </view>
  </view>
</view>
