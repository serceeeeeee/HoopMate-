<view class="hm-page with-tab">
  <view class="page-head">
    <view class="page-kicker">TRAINING LOG</view>
    <view class="page-title">训练记录</view>
    <view class="page-subtitle">手动录入投篮训练数据，支持示例数据、CSV 导入导出和单次训练详情。</view>
  </view>

  <view class="hm-card">
    <view class="section-header"><view><view class="section-title">新增训练</view><view class="section-subtitle">命中数不能大于出手数，保存后分析页自动更新</view></view><view class="section-action">{{previewRate}}%</view></view>
    <view class="form-item"><text class="label">训练日期</text><input class="input" value="{{form.training_date}}" data-field="training_date" bindinput="onInput" /></view>
    <view class="form-item"><text class="label">训练类型</text><view class="tag-row"><view wx:for="{{categories}}" wx:key="*this" class="tag {{form.category === item ? 'active' : ''}}" data-value="{{item}}" bindtap="chooseCategory">{{item}}</view></view></view>
    <view class="wrap-row">
      <view class="col-2"><view class="form-item"><text class="label">训练时长</text><input class="input" type="number" value="{{form.duration_min}}" data-field="duration_min" bindinput="onInput" /></view></view>
      <view class="col-2"><view class="form-item"><text class="label">强度 1-10</text><input class="input" type="number" value="{{form.intensity}}" data-field="intensity" bindinput="onInput" /></view></view>
      <view class="col-2"><view class="form-item"><text class="label">总投篮</text><input class="input" type="number" value="{{form.total_shots}}" data-field="total_shots" bindinput="onInput" /></view></view>
      <view class="col-2"><view class="form-item"><text class="label">总命中</text><input class="input" type="number" value="{{form.made_shots}}" data-field="made_shots" bindinput="onInput" /></view></view>
    </view>
    <view class="wrap-row">
      <view class="col-2"><view class="form-item"><text class="label">罚球出手</text><input class="input" type="number" value="{{form.free_throw_attempts}}" data-field="free_throw_attempts" bindinput="onInput" /></view></view>
      <view class="col-2"><view class="form-item"><text class="label">罚球命中</text><input class="input" type="number" value="{{form.free_throw_makes}}" data-field="free_throw_makes" bindinput="onInput" /></view></view>
      <view class="col-2"><view class="form-item"><text class="label">中投出手</text><input class="input" type="number" value="{{form.mid_attempts}}" data-field="mid_attempts" bindinput="onInput" /></view></view>
      <view class="col-2"><view class="form-item"><text class="label">中投命中</text><input class="input" type="number" value="{{form.mid_makes}}" data-field="mid_makes" bindinput="onInput" /></view></view>
      <view class="col-2"><view class="form-item"><text class="label">三分出手</text><input class="input" type="number" value="{{form.three_attempts}}" data-field="three_attempts" bindinput="onInput" /></view></view>
      <view class="col-2"><view class="form-item"><text class="label">三分命中</text><input class="input" type="number" value="{{form.three_makes}}" data-field="three_makes" bindinput="onInput" /></view></view>
    </view>
    <view class="form-item"><text class="label">训练备注</text><textarea class="textarea" value="{{form.note}}" data-field="note" bindinput="onInput" /></view>
    <button class="primary-btn" bindtap="save">保存训练记录</button>
  </view>

  <view class="hm-card">
    <view class="section-header"><view><view class="section-title">数据管理</view><view class="section-subtitle">CSV 导入导出在无后端时也可演示</view></view></view>
    <view class="btn-row">
      <button class="secondary-btn small-btn" bindtap="loadDemo">加载示例</button>
      <button class="ghost-btn small-btn" bindtap="importCsv">CSV 导入</button>
      <button class="ghost-btn small-btn" bindtap="exportCsv">CSV 导出</button>
    </view>
  </view>

  <view class="hm-card">
    <view class="section-header"><view><view class="section-title">训练记录列表</view><view class="section-subtitle">共 {{records.length}} 条，点击进入单次训练详情</view></view></view>
    <view wx:for="{{records}}" wx:key="id" class="record-card">
      <view class="row-between" bindtap="goDetail" data-id="{{item.id}}">
        <view>
          <view class="record-title">{{item.category}} · {{item.training_date}}</view>
          <view class="record-meta">{{item.duration_min}} min · 强度 {{item.intensity}} · 出手 {{item.total_shots}} · 命中 {{item.made_shots}}</view>
          <view class="record-meta">{{item.note}}</view>
        </view>
        <view style="text-align:right;">
          <view class="record-rate">{{item.shooting_rate}}%</view>
          <view class="tag {{item.tagLevel}}">{{item.tagText}}</view>
        </view>
      </view>
      <view class="divider"></view>
      <button class="danger-btn small-btn" data-id="{{item.id}}" bindtap="remove">删除记录</button>
    </view>
  </view>
</view>
