.shot-court{position:relative;width:100%;height:500rpx;background:#FAFBFC;border:2rpx solid #DDE2EA;border-radius:0 0 28rpx 28rpx;overflow:hidden;box-sizing:border-box}.rim{position:absolute;top:42rpx;left:50%;transform:translateX(-50%);width:50rpx;height:26rpx;border:4rpx solid #FF5A1F;border-radius:50%;box-sizing:border-box;z-index:5}.backboard{position:absolute;top:24rpx;left:50%;transform:translateX(-50%);width:150rpx;height:6rpx;background:#98A2B3;border-radius:6rpx;z-index:5}.paint-box{position:absolute;top:20rpx;left:50%;transform:translateX(-50%);width:220rpx;height:210rpx;border:2rpx solid #D4D9E2;border-top:none;box-sizing:border-box}.free-circle{position:absolute;top:146rpx;left:50%;transform:translateX(-50%);width:220rpx;height:160rpx;border:2rpx solid #D4D9E2;border-radius:50%;box-sizing:border-box}.three-arc{position:absolute;top:74rpx;left:50%;transform:translateX(-50%);width:610rpx;height:460rpx;border:3rpx solid #D4D9E2;border-top:none;border-radius:0 0 310rpx 310rpx;box-sizing:border-box}.shot-point{position:absolute;transform:translate(-50%,50%);z-index:10}.shot-point.made{width:16rpx;height:16rpx;border-radius:50%;background:#FF5A1F;border:3rpx solid #fff;box-shadow:0 0 0 1rpx #FF5A1F}.shot-point.miss{width:22rpx;height:22rpx;line-height:22rpx;text-align:center;font-size:24rpx;color:#667085;font-weight:800}.shot-legend{display:flex;justify-content:center;gap:34rpx;color:#667085;font-size:23rpx;margin-top:14rpx}.dot{display:inline-block;width:16rpx;height:16rpx;border-radius:50%;margin-right:8rpx;vertical-align:middle}.dot.made{background:#FF5A1F}.dot.miss{background:#667085}
