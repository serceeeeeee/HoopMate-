.hero { padding: 34rpx; }
.hero-top { position: relative; z-index: 1; }
.avatar {
  width: 86rpx;
  height: 86rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FDBA74;
  font-weight: 900;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
}
.hero-slogan {
  position: relative;
  z-index: 1;
  margin-top: 42rpx;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 900;
  max-width: 480rpx;
}
.hero-desc {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  color: #CBD5E1;
  font-size: 26rpx;
  line-height: 1.7;
}
.hero-actions {
  position: relative;
  z-index: 1;
  margin-top: 28rpx;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 18rpx;
  overflow: hidden;
}

.hero-actions button,
.hero-actions navigator,
.hero-actions .primary-btn,
.hero-actions .secondary-btn,
.hero-actions .ghost-btn {
  width: 100% !important;
  max-width: 100% !important;
  min-width: 0 !important;
  margin: 0 !important;
  padding: 0 12rpx !important;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
  white-space: nowrap;
}

.hero-actions button::after {
  border: none;
}
.recent-title { font-size: 32rpx; font-weight: 800; color: #F8FAFC; margin-bottom: 20rpx; }
.recent-metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; margin-bottom: 20rpx; }
.recent-metrics view { background: rgba(15,23,42,.84); border-radius: 20rpx; padding: 18rpx; }
.recent-metrics text:first-child { display: block; font-size: 34rpx; font-weight: 900; color: #FFB15E; }
.recent-metrics text:last-child { display: block; font-size: 22rpx; color: #94A3B8; margin-top: 6rpx; }
.flow-grid { display: grid; grid-template-columns: 1fr; gap: 16rpx; }
.flow-step { display: grid; grid-template-columns: 72rpx 160rpx 1fr; align-items: center; gap: 14rpx; padding: 20rpx; background: rgba(15, 23, 42, .72); border-radius: 22rpx; }
.flow-step view { width: 58rpx; height: 58rpx; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; background: rgba(255,122,26,.15); color: #FDBA74; font-weight: 900; }
.flow-step text:nth-child(2) { font-size: 28rpx; font-weight: 800; color: #F8FAFC; }
.flow-step text:nth-child(3) { font-size: 23rpx; color: #94A3B8; }
.quick-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.quick-item { background: rgba(255,255,255,.055); border-radius: 22rpx; padding: 22rpx; border: 1rpx solid rgba(255,255,255,.07); }
.quick-item text:first-child { display: block; font-size: 28rpx; font-weight: 800; color: #F8FAFC; }
.quick-item text:last-child { display: block; font-size: 22rpx; color: #94A3B8; margin-top: 8rpx; line-height: 1.45; }
