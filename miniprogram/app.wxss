page {
  background: #070B12;
  color: #F8FAFC;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.container, .hm-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: radial-gradient(circle at 88% 2%, rgba(255, 122, 26, 0.18), transparent 32%),
              radial-gradient(circle at 2% 14%, rgba(34, 211, 238, 0.12), transparent 30%),
              #070B12;
}

.card, .hm-card {
  background: rgba(21, 28, 46, 0.96);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  box-shadow: 0 20rpx 48rpx rgba(0, 0, 0, 0.28);
  box-sizing: border-box;
}

.card-highlight {
  background: linear-gradient(135deg, rgba(255, 122, 26, 0.22), rgba(21, 28, 46, 0.98) 52%, rgba(34, 211, 238, 0.11));
  border-color: rgba(255, 122, 26, 0.25);
  position: relative;
  overflow: hidden;
}
.card-highlight::after {
  content: "";
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  right: -120rpx;
  top: -140rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
  color: #F8FAFC;
  letter-spacing: 1rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 900;
  color: #F8FAFC;
  letter-spacing: 1rpx;
}

.page-subtitle, .muted {
  color: #94A3B8;
  font-size: 25rpx;
  line-height: 1.6;
}

.primary-btn, .secondary-btn, .ghost-btn, .danger-btn {
  border-radius: 22rpx;
  font-weight: 700;
  font-size: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  margin: 0;
}
.primary-btn {
  background: linear-gradient(135deg, #FF7A1A, #F59E0B);
  color: #FFFFFF;
  box-shadow: 0 14rpx 30rpx rgba(255, 122, 26, 0.28);
}
.secondary-btn {
  background: rgba(34, 211, 238, 0.10);
  color: #67E8F9;
  border: 1rpx solid rgba(34, 211, 238, 0.22);
}
.ghost-btn {
  background: rgba(255, 255, 255, 0.06);
  color: #E2E8F0;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}
.danger-btn {
  background: rgba(239, 68, 68, 0.10);
  color: #FCA5A5;
  border: 1rpx solid rgba(239, 68, 68, 0.25);
}

.btn-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.input, .textarea, .picker-box {
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  border-radius: 18rpx;
  padding: 20rpx 22rpx;
  background: rgba(15, 23, 42, 0.9);
  color: #F8FAFC;
  min-height: 48rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.textarea {
  min-height: 140rpx;
  width: 100%;
}
.input::placeholder, .textarea::placeholder {
  color: #64748B;
}
.form-item {
  margin-bottom: 24rpx;
}
.label {
  font-size: 27rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  display: block;
  color: #CBD5E1;
}

.metric-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}
.metric-card {
  background: linear-gradient(180deg, rgba(30, 41, 59, 0.92), rgba(15, 23, 42, 0.92));
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  min-height: 142rpx;
  box-sizing: border-box;
}
.metric-value {
  font-size: 46rpx;
  font-weight: 900;
  color: #F8FAFC;
  line-height: 1.1;
}
.metric-value.accent { color: #FFB15E; }
.metric-value.cyan { color: #67E8F9; }
.metric-label {
  font-size: 23rpx;
  color: #94A3B8;
  margin-top: 10rpx;
}
.metric-trend {
  display: inline-flex;
  margin-top: 12rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #34D399;
  background: rgba(52, 211, 153, 0.12);
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.tag {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  color: #CBD5E1;
  font-size: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}
.tag.active {
  background: rgba(255, 122, 26, 0.16);
  color: #FDBA74;
  border-color: rgba(255, 122, 26, 0.35);
}
.tag.cyan {
  background: rgba(34, 211, 238, 0.10);
  color: #67E8F9;
  border-color: rgba(34, 211, 238, 0.22);
}
.tag.green {
  background: rgba(52, 211, 153, 0.10);
  color: #86EFAC;
  border-color: rgba(52, 211, 153, 0.22);
}
.tag.warn {
  background: rgba(245, 158, 11, 0.12);
  color: #FCD34D;
  border-color: rgba(245, 158, 11, 0.22);
}

.progress {
  height: 18rpx;
  background: rgba(30, 41, 59, 0.95);
  border-radius: 999rpx;
  overflow: hidden;
  margin-top: 12rpx;
}
.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #22D3EE, #FF7A1A);
  border-radius: 999rpx;
}
.row-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}
.divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.07);
  margin: 22rpx 0;
}
.empty {
  padding: 42rpx 20rpx;
  text-align: center;
  color: #94A3B8;
  font-size: 26rpx;
  line-height: 1.6;
}
.two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}
.one-line {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
