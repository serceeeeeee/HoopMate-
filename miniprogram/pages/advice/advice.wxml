<view class="hm-page">
  <view class="page-head"><view class="page-kicker">TRAINING PLAN</view><view class="page-title">训练建议</view><view class="page-subtitle">根据训练数据生成规则化建议和下一周训练计划。</view></view>
  <view class="hm-card"><view class="section-header"><view><view class="section-title">本周建议重点</view><view class="section-subtitle">保持训练频率，重点提升薄弱区域</view></view></view><view wx:for="{{advices}}" wx:key="title" class="record-card"><view class="row-between"><view class="record-title">{{item.title}}</view><view class="tag active">{{item.priority}}</view></view><view class="record-meta">{{item.text}}</view><view class="record-meta">建议动作：{{item.action}}</view></view></view>
  <view class="hm-card"><view class="section-header"><view><view class="section-title">下一周训练计划</view><view class="section-subtitle">可作为实习项目 Demo 展示计划</view></view></view><view wx:for="{{plans}}" wx:key="day" class="record-card"><view class="row-between"><view class="record-title">{{item.day}} · {{item.title}}</view><view class="tag good">{{item.duration}}</view></view><view class="record-meta">{{item.content}}</view></view></view>
</view>
