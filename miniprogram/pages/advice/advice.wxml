<view class="hm-page advice-page">
  <view class="hm-card card-highlight status-card">
    <view class="page-title">训练建议</view>
    <view class="page-subtitle">基于最近训练频率、命中率、训练强度和项目占比生成。</view>
    <view class="status-main">{{status}}</view>
    <view class="tag active">{{statusTag}}</view>
  </view>

  <view class="hm-card">
    <view class="row-between">
      <view class="section-title">规则化训练建议</view>
      <view class="tag cyan">{{cards.length}} 条</view>
    </view>
    <block wx:if="{{cards.length}}">
      <view wx:for="{{cards}}" wx:key="id" class="advice-card">
        <view class="row-between">
          <view class="advice-title">{{item.title}}</view>
          <view class="tag {{item.priority === '高' ? 'warn' : 'cyan'}}">优先级 {{item.priority}}</view>
        </view>
        <view class="advice-content">{{item.content}}</view>
        <view class="advice-footer">
          <text>{{item.type}}</text>
          <text>目标：{{item.target}}</text>
        </view>
      </view>
    </block>
    <view wx:else class="empty">暂无建议，请先记录训练数据。</view>
  </view>

  <view class="hm-card">
    <view class="section-title">下一周训练计划</view>
    <view wx:for="{{plan}}" wx:key="day" class="plan-row">
      <view class="plan-day">{{item.day}}</view>
      <view class="plan-main">
        <view>{{item.title}}</view>
        <text>{{item.detail}}</text>
      </view>
      <view class="plan-time">{{item.minutes}} min</view>
    </view>
  </view>

  <view class="hm-card">
    <view class="section-title">建议依据</view>
    <view class="basis-grid">
      <view><text>{{summary.avg_shooting_rate || 0}}%</text><text>整体命中率</text></view>
      <view><text>{{summary.three_rate || 0}}%</text><text>三分命中率</text></view>
      <view><text>{{summary.avg_intensity || 0}}</text><text>平均强度</text></view>
      <view><text>{{summary.recent_7day_sessions || 0}}</text><text>近 7 天训练</text></view>
    </view>
    <view class="btn-row action-row">
      <button class="secondary-btn" bindtap="refreshAdvice">重新生成</button>
      <button class="primary-btn" bindtap="goRecord">记录下一次</button>
    </view>
  </view>
</view>
