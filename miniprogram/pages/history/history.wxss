.history-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,.07);
}
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}
.item-title {
  font-size: 30rpx;
  font-weight: 850;
  color: #F8FAFC;
  margin-bottom: 8rpx;
}
.note {
  background: rgba(15,23,42,.76);
  border-radius: 18rpx;
  padding: 16rpx;
  margin-top: 14rpx;
  color: #CBD5E1;
  font-size: 26rpx;
}
