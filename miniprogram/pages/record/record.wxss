.tool-grid {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
  margin-top: 26rpx;
  overflow: hidden;
}

.tool-grid button,
.tool-grid .primary-btn,
.tool-grid .secondary-btn,
.tool-grid .ghost-btn {
  width: 100% !important;
  max-width: 100% !important;
  min-width: 0 !important;
  margin: 0 !important;
  padding: 0 12rpx !important;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
  white-space: nowrap;
}

.tool-grid button::after {
  border: none;
}
.export-tip { margin-top: 18rpx; color: #94A3B8; font-size: 22rpx; line-height: 1.5; word-break: break-all; }
.shot-panel { background: rgba(15,23,42,.76); border-radius: 24rpx; padding: 22rpx; margin-bottom: 22rpx; border: 1rpx solid rgba(255,255,255,.06); }
.shot-title { font-size: 26rpx; font-weight: 800; color: #CBD5E1; margin-bottom: 14rpx; }
.shot-grid { display: grid; grid-template-columns: 1fr; gap: 16rpx; margin-bottom: 24rpx; }
.shot-mini { background: rgba(255,255,255,.04); border-radius: 22rpx; padding: 20rpx; }
.session-card { background: rgba(15,23,42,.72); border-radius: 24rpx; padding: 24rpx; margin-bottom: 18rpx; border: 1rpx solid rgba(255,255,255,.06); }
.session-title { font-size: 30rpx; font-weight: 850; color: #F8FAFC; margin-bottom: 8rpx; }
.rate-pill { min-width: 108rpx; height: 62rpx; line-height: 62rpx; text-align: center; border-radius: 999rpx; background: rgba(255,122,26,.16); color: #FDBA74; font-weight: 900; font-size: 28rpx; }
.session-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; margin-bottom: 14rpx; }
.session-stats text { font-size: 24rpx; color: #CBD5E1; background: rgba(255,255,255,.04); border-radius: 16rpx; padding: 12rpx; }
.note { margin-bottom: 16rpx; }
.small-btn { height: 70rpx; line-height: 70rpx; font-size: 25rpx; }
