.record-card{background:#fff;border:1rpx solid #E8EBF0;border-radius:24rpx;padding:24rpx;margin-bottom:18rpx;box-sizing:border-box}.record-top{display:flex;justify-content:space-between;align-items:flex-start;gap:18rpx}.record-title{font-size:29rpx;font-weight:800;color:#1F2933}.record-meta{font-size:23rpx;color:#8A8F98;margin-top:8rpx}.rate-tag{border-radius:999rpx;padding:8rpx 14rpx;font-size:21rpx;font-weight:800;white-space:nowrap;background:#F2F4F7;color:#667085}.rate-tag.excellent{background:#EAF8F0;color:#18A058}.rate-tag.good{background:#FFF2EC;color:#FF5A1F}.rate-tag.work{background:#FFF7E6;color:#B45309}.record-data{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx;margin-top:20rpx;background:#F7F8FA;border-radius:18rpx;padding:18rpx 8rpx}.record-data view{text-align:center}.record-data text:first-child{display:block;font-size:32rpx;color:#14171F;font-weight:800}.record-data text:last-child{display:block;font-size:21rpx;color:#8A8F98;margin-top:4rpx}.record-note{font-size:24rpx;color:#667085;line-height:1.5;margin-top:18rpx}.record-actions{display:flex;gap:14rpx;margin-top:18rpx}.detail-btn,.delete-btn{height:62rpx;line-height:62rpx;border-radius:14rpx;font-size:24rpx;font-weight:700;margin:0;flex:1}.detail-btn{background:#FFF2EC;color:#FF5A1F;border:1rpx solid #FFD5C6}.delete-btn{background:#FFF2F2;color:#D92D20;border:1rpx solid #FFD7D7}
