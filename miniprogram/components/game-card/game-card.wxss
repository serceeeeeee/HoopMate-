.game-card{background:#fff;border:1rpx solid #E8EBF0;border-radius:22rpx;padding:22rpx;margin-bottom:18rpx}.game-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx}.league{font-size:23rpx;color:#667085;font-weight:700}.status{font-size:21rpx;font-weight:800;border-radius:999rpx;padding:6rpx 12rpx;background:#F2F4F7;color:#667085}.status.Live{background:#FFF2EC;color:#FF5A1F}.status.Finished{background:#EAF8F0;color:#18A058}.status.Upcoming{background:#EFF6FF;color:#2F80ED}.team-row{display:flex;justify-content:space-between;align-items:center;font-size:30rpx;color:#1F2933;font-weight:800;padding:8rpx 0}.score{font-size:36rpx;color:#14171F}.game-meta{font-size:22rpx;color:#8A8F98;margin-top:12rpx}
