.status-card { min-height: 320rpx; }
.status-main { margin-top: 40rpx; font-size: 44rpx; font-weight: 900; color: #FFFFFF; }
.advice-card { background: rgba(15,23,42,.76); border-radius: 24rpx; padding: 24rpx; margin-bottom: 18rpx; border: 1rpx solid rgba(255,255,255,.06); }
.advice-title { font-size: 30rpx; font-weight: 900; color: #F8FAFC; }
.advice-content { margin-top: 18rpx; color: #CBD5E1; font-size: 27rpx; line-height: 1.7; }
.advice-footer { display: flex; justify-content: space-between; gap: 16rpx; margin-top: 18rpx; color: #94A3B8; font-size: 22rpx; }
.plan-row { display: grid; grid-template-columns: 92rpx 1fr 116rpx; gap: 18rpx; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid rgba(255,255,255,.07); }
.plan-day { height: 62rpx; line-height: 62rpx; text-align: center; border-radius: 20rpx; background: rgba(255,122,26,.16); color: #FDBA74; font-weight: 900; }
.plan-main view { font-size: 29rpx; color: #F8FAFC; font-weight: 850; margin-bottom: 6rpx; }
.plan-main text { font-size: 23rpx; color: #94A3B8; }
.plan-time { font-size: 24rpx; color: #67E8F9; text-align: right; }
.basis-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.basis-grid view { background: rgba(255,255,255,.055); border-radius: 20rpx; padding: 20rpx; }
.basis-grid text:first-child { display: block; font-size: 34rpx; font-weight: 900; color: #F8FAFC; }
.basis-grid text:last-child { display: block; font-size: 22rpx; color: #94A3B8; margin-top: 8rpx; }
.action-row { margin-top: 24rpx; }
.action-row {
  margin-top: 24rpx;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 18rpx;
  overflow: hidden;
}

.action-row button,
.action-row .action-btn {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
}

.action-row button::after {
  border: none;
}
