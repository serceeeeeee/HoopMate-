.shot-heatmap-card{background:#fff;border:1rpx solid #E5E7EB;border-radius:24rpx;padding:24rpx;box-sizing:border-box}.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:18rpx}.section-title{color:#111827;font-size:32rpx;font-weight:800;line-height:1.3}.section-subtitle{color:#8A94A6;font-size:23rpx;line-height:1.45;margin-top:4rpx}.section-action{color:#FF5A1F;font-size:24rpx;font-weight:800}.heatmap-summary-row{display:flex;border:1rpx solid #E9EDF3;border-radius:18rpx;overflow:hidden;margin-bottom:24rpx;background:#fff}.heatmap-summary-item{flex:1;padding:18rpx 8rpx 16rpx;text-align:center;border-right:1rpx solid #E9EDF3;box-sizing:border-box}.heatmap-summary-item:last-child{border-right:none}.heatmap-summary-value{color:#111827;font-size:39rpx;font-weight:800;line-height:1.1;letter-spacing:-1rpx}.heatmap-summary-label{color:#667085;font-size:22rpx;font-weight:800;margin-top:8rpx}.heatmap-summary-sub{color:#9AA3AF;font-size:21rpx;margin-top:3rpx}.court-heatmap-v3{position:relative;width:100%;height:520rpx;border:2rpx solid #DDE2EA;border-radius:12rpx;overflow:hidden;box-sizing:border-box;background:#F4F5F7}.heat-zone-v3{position:absolute;z-index:2;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;box-sizing:border-box;border:3rpx solid rgba(255,255,255,.95);padding:4rpx;overflow:hidden}.heat-zone-v3.is-selected{z-index:7;border-color:#111827;border-width:4rpx}.heat-zone-v3-name{font-size:23rpx;line-height:1.1;font-weight:800;color:inherit;white-space:nowrap}.heat-zone-v3-rate{font-size:35rpx;line-height:1.05;font-weight:900;letter-spacing:-1rpx;margin-top:6rpx;color:inherit;white-space:nowrap}.heat-zone-v3-sub{font-size:23rpx;line-height:1.1;font-weight:700;margin-top:6rpx;color:inherit;opacity:.78;white-space:nowrap}.zone-v3-left-mid{left:7%;top:0;width:31%;height:32%}.zone-v3-center-mid{left:38%;top:0;width:24%;height:32%}.zone-v3-right-mid{left:62%;top:0;width:31%;height:32%}.zone-v3-left-paint{left:28%;top:32%;width:19%;height:34%}.zone-v3-center-paint{left:47%;top:32%;width:20%;height:34%}.zone-v3-right-paint{left:67%;top:32%;width:19%;height:34%}.zone-v3-left-corner{left:0;top:54%;width:28%;height:46%}.zone-v3-top-arc{left:28%;top:66%;width:44%;height:34%}.zone-v3-right-corner{left:72%;top:54%;width:28%;height:46%}.court-v3-line{position:absolute;z-index:5;pointer-events:none;box-sizing:border-box}.court-v3-three-arc{left:10%;top:18%;width:80%;height:72%;border:5rpx solid rgba(255,255,255,.96);border-top:none;border-radius:0 0 480rpx 480rpx}.court-v3-lane{left:36%;top:0;width:28%;height:42%;border-left:5rpx solid rgba(255,255,255,.96);border-right:5rpx solid rgba(255,255,255,.96);border-bottom:5rpx solid rgba(255,255,255,.96)}.court-v3-free-circle{left:36%;top:30%;width:28%;height:26%;border:5rpx solid rgba(255,255,255,.96);border-radius:50%}.court-v3-backboard{left:43%;top:8%;width:14%;height:0;border-top:5rpx solid rgba(255,255,255,.98)}.court-v3-rim{left:47%;top:10.5%;width:6%;height:6%;border:5rpx solid rgba(255,255,255,.98);border-radius:50%}.heatmap-legend-row{display:flex;align-items:center;justify-content:space-between;margin-top:20rpx;color:#8A94A6;font-size:22rpx}.legend-pair{display:flex;align-items:center;white-space:nowrap}.legend-swatch{width:22rpx;height:22rpx;border-radius:6rpx;margin-right:8rpx;border:1rpx solid #E4E7EC;box-sizing:border-box}.legend-swatch.empty{background:#F1F2F4}.legend-gradient{display:flex;align-items:center;flex:1;margin:0 18rpx;height:18rpx;border-radius:999rpx;overflow:hidden}.legend-step{flex:1;height:100%}.legend-step.s1{background:#FFE6D9}.legend-step.s2{background:#FFC7AD}.legend-step.s3{background:#FF9B63}.legend-step.s4{background:#FF5A1F}.legend-labels{display:flex;align-items:center;justify-content:space-between;width:72rpx;color:#8A94A6}.selected-zone-panel{display:flex;align-items:center;justify-content:space-between;margin-top:18rpx;padding:20rpx 22rpx;border-radius:18rpx;background:#fff;border:1rpx solid #E5E7EB}.selected-zone-name{color:#111827;font-size:27rpx;font-weight:800;line-height:1.25}.selected-zone-meta{color:#7A818C;font-size:22rpx;margin-top:6rpx}.selected-zone-rate{color:#FF5A1F;font-size:42rpx;font-weight:900;letter-spacing:-1rpx}.heatmap-insight{margin-top:18rpx;padding:18rpx 20rpx;background:#FFF7F2;border:1rpx solid #FFD6C8;border-radius:18rpx;color:#5F3828;font-size:24rpx;line-height:1.55}
