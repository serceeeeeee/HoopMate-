<view class="hm-page with-tab">
  <view class="page-head">
    <view class="page-kicker">HOOPMATE DASHBOARD</view>
    <view class="page-title">篮球训练总览</view>
    <view class="page-subtitle">首页使用本地演示数据兜底，即使后端未启动也会正常显示。</view>
  </view>

  <view class="hm-card">
    <view class="row-between">
      <view>
        <view class="metric-label">{{todayStatus}}</view>
        <view class="metric-value orange" style="font-size:72rpx;">{{summary.avg_shooting_rate}}<text class="metric-unit">%</text></view>
        <view class="metric-sub">总命中率 · {{summary.made_shots}} / {{summary.total_shots}}</view>
      </view>
      <view class="metric-box" style="width:190rpx;text-align:center;min-height:150rpx;">
        <view class="metric-value">{{summary.recent_7day_sessions}}</view>
        <view class="metric-sub">近7天训练</view>
      </view>
    </view>
    <view class="divider"></view>
    <view class="wrap-row">
      <view class="col-3"><view class="metric-label">总投篮</view><view class="record-title">{{summary.total_shots}}</view></view>
      <view class="col-3"><view class="metric-label">总命中</view><view class="record-title">{{summary.made_shots}}</view></view>
      <view class="col-3"><view class="metric-label">近7天变化</view><view class="record-title orange">{{rateChangeText}}</view></view>
    </view>
  </view>

  <view class="wrap-row">
    <view class="col-2"><view class="metric-box"><view class="metric-label">今日训练状态</view><view class="metric-value orange" style="font-size:38rpx;">{{todayStatusShort}}</view><view class="metric-sub">最近：{{summary.latest_date}}</view></view></view>
    <view class="col-2"><view class="metric-box"><view class="metric-label">本周目标</view><view class="metric-value">{{summary.recent_7day_sessions}}/{{profile.weekly_goal_sessions}}</view><view class="metric-sub">完成度 {{weekProgress}}%</view></view></view>
    <view class="col-2"><view class="metric-box"><view class="metric-label">禁区命中率</view><view class="metric-value">{{summary.paint_rate}}<text class="metric-unit">%</text></view><view class="metric-sub">篮下效率</view></view></view>
    <view class="col-2"><view class="metric-box"><view class="metric-label">三分命中率</view><view class="metric-value">{{summary.three_rate}}<text class="metric-unit">%</text></view><view class="metric-sub">外线表现</view></view></view>
  </view>

  <view class="hm-card">
    <view class="section-header">
      <view><view class="section-title">本周目标完成度</view><view class="section-subtitle">根据个人档案中的每周训练目标计算</view></view>
      <view class="section-action">{{weekProgress}}%</view>
    </view>
    <view class="progress-track"><view class="progress-fill" style="width: {{weekProgress}}%;"></view></view>
  </view>

  <view class="hm-card">
    <view class="section-header"><view><view class="section-title">快速入口</view><view class="section-subtitle">开始训练、查看分析、资讯和赛事</view></view></view>
    <view class="quick-wrap">
      <view class="quick-item quick-primary" bindtap="goRecord"><view class="quick-inner"><view class="quick-title">开始训练</view><view class="quick-desc">新增训练记录</view></view></view>
      <view class="quick-item" bindtap="goAnalysis"><view class="quick-inner"><view class="quick-title">查看分析</view><view class="quick-desc">热区与趋势</view></view></view>
      <view class="quick-item" bindtap="goNews"><view class="quick-inner"><view class="quick-title">篮球新闻</view><view class="quick-desc">资讯与技巧</view></view></view>
      <view class="quick-item" bindtap="goGames"><view class="quick-inner"><view class="quick-title">赛事数据</view><view class="quick-desc">赛程和比分</view></view></view>
      <view class="quick-item" bindtap="seedDemo"><view class="quick-inner"><view class="quick-title">刷新示例</view><view class="quick-desc">恢复演示数据</view></view></view>
      <view class="quick-item" bindtap="goProfile"><view class="quick-inner"><view class="quick-title">个人档案</view><view class="quick-desc">目标与设置</view></view></view>
    </view>
  </view>

  <view class="hm-card">
    <view class="section-header"><view><view class="section-title">核心使用流程</view><view class="section-subtitle">3 步完成一次篮球训练复盘</view></view></view>
    <view class="record-card"><view class="record-title">1. 记录训练</view><view class="record-meta">录入投篮、命中、时长、强度和备注。</view></view>
    <view class="record-card"><view class="record-title">2. 分析表现</view><view class="record-meta">查看命中率、球场热区、投篮点位和训练趋势。</view></view>
    <view class="record-card"><view class="record-title">3. 调整计划</view><view class="record-meta">根据建议安排下一周训练重点。</view></view>
  </view>

  <view class="hm-card">
    <view class="section-header"><view><view class="section-title">最近训练</view><view class="section-subtitle">点击卡片进入单次训练详情</view></view><view class="section-action" bindtap="goRecord">全部</view></view>
    <view class="record-card" bindtap="goDetail" wx:if="{{latest.id}}">
      <view class="row-between">
        <view>
          <view class="record-title">{{latest.category}} · {{latest.training_date}}</view>
          <view class="record-meta">{{latest.duration_min}} min · 强度 {{latest.intensity}} · {{latest.total_shots}} 次出手</view>
        </view>
        <view class="record-rate">{{latest.shooting_rate}}%</view>
      </view>
      <view class="record-meta">{{latest.note}}</view>
    </view>
  </view>
</view>
