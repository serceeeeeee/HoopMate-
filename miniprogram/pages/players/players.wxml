<view class="hm-page">
  <view class="page-head"><view class="page-kicker">PLAYER DATA</view><view class="page-title">球员数据展示</view><view class="page-subtitle">使用合成示例数据展示表格、柱状图和数据分析能力。</view></view>
  <view class="hm-card"><view class="section-header"><view><view class="section-title">得分柱状图</view><view class="section-subtitle">柱高表示场均得分</view></view></view><view class="trend-card"><view wx:for="{{players}}" wx:key="name" class="trend-col"><view class="trend-bar" style="height: {{item.height}}%;"></view><view class="trend-label">{{item.name}}</view></view></view></view>
  <view class="hm-card"><view class="section-header"><view><view class="section-title">球员数据表</view><view class="section-subtitle">合成数据，不代表真实比赛结果</view></view></view><view wx:for="{{players}}" wx:key="name" class="record-card"><view class="row-between"><view><view class="record-title">{{item.name}} · {{item.position}}</view><view class="record-meta">篮板 {{item.rebounds}} · 助攻 {{item.assists}} · 命中率 {{item.rate}}%</view></view><view class="record-rate">{{item.points}}</view></view></view></view>
</view>
