.metric-card{background:#fff;border:1rpx solid #E8EBF0;border-radius:24rpx;padding:24rpx;min-height:150rpx;box-sizing:border-box}.metric-value{font-size:48rpx;font-weight:800;line-height:1.08;color:#14171F;letter-spacing:-1rpx}.metric-card.accent .metric-value{color:#FF5A1F}.metric-card.blue .metric-value{color:#2F80ED}.metric-card.green .metric-value{color:#18A058}.unit{font-size:24rpx;font-weight:700;margin-left:4rpx}.metric-title{font-size:23rpx;color:#7A818C;margin-top:10rpx}.metric-subtitle{font-size:21rpx;color:#A4ABB6;margin-top:6rpx}.metric-trend{display:inline-flex;margin-top:12rpx;border-radius:999rpx;padding:6rpx 12rpx;background:#FFF2EC;color:#FF5A1F;font-size:20rpx;font-weight:700}
