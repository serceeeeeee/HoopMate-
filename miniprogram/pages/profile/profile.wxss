.profile-head { text-align: center; }
.avatar-large { width: 132rpx; height: 132rpx; margin: 6rpx auto 20rpx; border-radius: 42rpx; background: linear-gradient(135deg, #FF7A1A, #22D3EE); display: flex; align-items: center; justify-content: center; font-size: 58rpx; font-weight: 900; color: #fff; }
.profile-name { font-size: 38rpx; font-weight: 900; margin-bottom: 18rpx; }
.center-tags { justify-content: center; }
.quick-list { display: grid; grid-template-columns: 1fr; gap: 16rpx; }
.quick-row { padding: 22rpx; border-radius: 22rpx; background: rgba(15,23,42,.76); border: 1rpx solid rgba(255,255,255,.06); }
.quick-row text:first-child { display: block; font-size: 29rpx; color: #F8FAFC; font-weight: 850; }
.quick-row text:last-child { display: block; color: #94A3B8; font-size: 23rpx; margin-top: 8rpx; }
.quick-row.danger text:first-child { color: #FCA5A5; }
.export-tip { margin-top: 18rpx; color: #94A3B8; font-size: 22rpx; line-height: 1.5; word-break: break-all; }
