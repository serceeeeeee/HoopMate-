page {
  min-height: 100vh;
  background: #F7F8FA;
  color: #1F2933;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
}
.hm-page { min-height: 100vh; padding: 24rpx 24rpx 54rpx; box-sizing: border-box; background: #F7F8FA; }
.with-tab { padding-bottom: 148rpx; }
.page-head { padding: 8rpx 0 24rpx; }
.page-kicker { color: #FF5A1F; font-size: 21rpx; font-weight: 700; letter-spacing: 1rpx; margin-bottom: 8rpx; }
.page-title { color: #111827; font-size: 42rpx; line-height: 1.2; font-weight: 800; }
.page-subtitle { color: #7A818C; font-size: 25rpx; line-height: 1.55; margin-top: 8rpx; }
.hm-card { background: #FFFFFF; border: 1rpx solid #E6E9EF; border-radius: 26rpx; padding: 26rpx; margin-bottom: 22rpx; box-sizing: border-box; }
.card-soft { background: #F9FAFC; border: 1rpx solid #E8EBF0; border-radius: 22rpx; padding: 22rpx; box-sizing: border-box; }
.row-between { display: flex; align-items: center; justify-content: space-between; }
.row-start { display: flex; align-items: center; }
.divider { height: 1rpx; background: #ECEFF4; margin: 22rpx 0; }
.wrap-row { display: flex; flex-wrap: wrap; margin-left: -8rpx; margin-right: -8rpx; }
.col-2 { width: 50%; padding: 8rpx; box-sizing: border-box; }
.col-3 { width: 33.333%; padding: 8rpx; box-sizing: border-box; }
.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18rpx; }
.section-title { color: #111827; font-size: 31rpx; font-weight: 800; line-height: 1.3; }
.section-subtitle { color: #8A8F98; font-size: 23rpx; line-height: 1.45; margin-top: 4rpx; }
.section-action { color: #FF5A1F; font-size: 24rpx; font-weight: 700; }
.metric-box { background: #FFFFFF; border: 1rpx solid #E6E9EF; border-radius: 22rpx; padding: 22rpx; min-height: 144rpx; box-sizing: border-box; }
.metric-label { color: #7A818C; font-size: 23rpx; line-height: 1.3; }
.metric-value { color: #111827; font-size: 46rpx; font-weight: 800; line-height: 1.15; margin-top: 10rpx; }
.metric-value.orange, .orange { color: #FF5A1F; }
.metric-unit { font-size: 24rpx; font-weight: 700; margin-left: 4rpx; }
.metric-sub { color: #8A8F98; font-size: 22rpx; margin-top: 8rpx; line-height: 1.4; }
.primary-btn, .secondary-btn, .ghost-btn, .danger-btn { border-radius: 18rpx; font-weight: 700; font-size: 28rpx; height: 84rpx; line-height: 84rpx; padding: 0 24rpx; margin: 0; box-sizing: border-box; }
.primary-btn { background: #FF5A1F; color: #FFFFFF; border: 1rpx solid #FF5A1F; }
.secondary-btn { background: #FFF2EC; color: #FF5A1F; border: 1rpx solid #FFD6C8; }
.ghost-btn { background: #FFFFFF; color: #3B424C; border: 1rpx solid #DDE2EA; }
.danger-btn { background: #FFF1F1; color: #D92D20; border: 1rpx solid #FFD3D3; }
.small-btn { height: 60rpx; line-height: 60rpx; font-size: 24rpx; border-radius: 14rpx; padding: 0 18rpx; }
.btn-row { display: flex; flex-wrap: wrap; margin-left: -8rpx; margin-right: -8rpx; }
.btn-row button { flex: 1; margin: 8rpx; min-width: 0; }
.input, .textarea, .picker-box { width: 100%; background: #FFFFFF; border: 1rpx solid #DDE2EA; color: #1F2933; border-radius: 16rpx; min-height: 82rpx; padding: 16rpx 18rpx; box-sizing: border-box; font-size: 28rpx; }
.textarea { min-height: 138rpx; line-height: 1.55; }
.form-item { margin-bottom: 22rpx; }
.label { display: block; color: #3B424C; font-size: 25rpx; font-weight: 700; margin-bottom: 12rpx; }
.tag-row { display: flex; flex-wrap: wrap; margin: -6rpx; }
.tag, .range-chip, .status-chip { display: inline-flex; align-items: center; justify-content: center; min-height: 46rpx; border-radius: 999rpx; padding: 8rpx 16rpx; background: #F5F6F8; color: #68707D; font-size: 22rpx; font-weight: 700; margin: 6rpx; box-sizing: border-box; }
.tag.active, .range-chip.active, .status-chip.active { background: #FFF2EC; color: #FF5A1F; border: 1rpx solid #FFD6C8; }
.tag.good { background: #EAF8F0; color: #18A058; }
.tag.warn { background: #FFF7E6; color: #B45309; }
.tag.work { background: #F2F4F7; color: #667085; }
.tag.excellent { background: #FFF2EC; color: #FF5A1F; }
.record-card { background: #FFFFFF; border: 1rpx solid #E6E9EF; border-radius: 22rpx; padding: 22rpx; margin-bottom: 18rpx; box-sizing: border-box; }
.record-title { color: #111827; font-size: 29rpx; font-weight: 800; }
.record-meta { color: #7A818C; font-size: 23rpx; margin-top: 8rpx; line-height: 1.45; }
.record-rate { color: #FF5A1F; font-size: 40rpx; font-weight: 800; }
.progress-track { height: 12rpx; border-radius: 999rpx; background: #EEF1F5; overflow: hidden; }
.progress-fill { height: 100%; border-radius: 999rpx; background: #FF5A1F; }
.empty-state { background: #FFFFFF; border: 1rpx dashed #DDE2EA; border-radius: 22rpx; padding: 34rpx 24rpx; text-align: center; color: #8A8F98; }
.empty-title { color: #3B424C; font-size: 28rpx; font-weight: 800; margin-bottom: 8rpx; }
.empty-desc { font-size: 24rpx; line-height: 1.5; margin-bottom: 18rpx; }
.loading-text { color: #8A8F98; font-size: 24rpx; text-align: center; padding: 28rpx; }
/* 可视化通用样式 */
.court { position: relative; height: 520rpx; background: #FAFBFC; border: 2rpx solid #DDE2EA; border-radius: 0 0 260rpx 260rpx; overflow: hidden; box-sizing: border-box; }
.court-line { position: absolute; border: 2rpx solid #E1E5EC; box-sizing: border-box; }
.paint-line { left: 33%; top: 0; width: 34%; height: 38%; border-top: none; }
.ft-line { left: 36%; top: 25%; width: 28%; height: 25%; border-radius: 50%; }
.arc-line { left: 8%; top: 14%; width: 84%; height: 72%; border-radius: 0 0 999rpx 999rpx; border-top: none; }
.hoop-line { left: 47%; top: 5%; width: 6%; height: 6%; border-radius: 50%; }
.heat-zone { position: absolute; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: 13rpx; border: 2rpx solid rgba(255,255,255,.85); text-align: center; box-sizing: border-box; z-index: 2; }
.heat-zone .z-name { font-size: 19rpx; font-weight: 700; line-height: 1.1; }
.heat-zone .z-rate { font-size: 25rpx; font-weight: 800; line-height: 1.1; margin-top: 3rpx; }
.heat-zone .z-sub { font-size: 17rpx; font-weight: 700; opacity: .72; margin-top: 2rpx; }
.legend { display: flex; align-items: center; justify-content: space-between; margin-top: 18rpx; color: #8A8F98; font-size: 22rpx; }
.legend-colors { display: flex; align-items: center; }
.legend-block { width: 34rpx; height: 16rpx; margin-right: 4rpx; border-radius: 4rpx; }
.shot-point { position: absolute; width: 18rpx; height: 18rpx; margin-left: -9rpx; margin-top: -9rpx; border-radius: 50%; background: #FF5A1F; border: 2rpx solid #FFFFFF; z-index: 3; box-sizing: border-box; }
.shot-point.miss { background: transparent; border: none; color: #64748B; font-size: 24rpx; line-height: 18rpx; font-weight: 800; text-align: center; }
.trend-card { display: flex; align-items: flex-end; height: 220rpx; border-bottom: 1rpx solid #E6E9EF; border-left: 1rpx solid #E6E9EF; padding: 12rpx 8rpx 0; box-sizing: border-box; }
.trend-col { flex: 1; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; }
.trend-bar { width: 20rpx; min-height: 8rpx; border-radius: 999rpx 999rpx 0 0; background: #FF5A1F; }
.trend-dot { width: 18rpx; height: 18rpx; border-radius: 50%; background: #FF5A1F; margin-bottom: 4rpx; }
.trend-label { color: #98A2B3; font-size: 18rpx; margin-top: 8rpx; }
.quick-wrap { display: flex; flex-wrap: wrap; margin: -8rpx; }
.quick-item { width: 50%; padding: 8rpx; box-sizing: border-box; }
.quick-inner { border: 1rpx solid #E6E9EF; background: #FFFFFF; border-radius: 20rpx; padding: 22rpx; }
.quick-title { color: #111827; font-size: 27rpx; font-weight: 800; }
.quick-desc { color: #8A8F98; font-size: 22rpx; margin-top: 6rpx; }
.quick-primary .quick-inner { background: #FFF2EC; border-color: #FFD6C8; }

/* 专业分区投篮热区图：白底 iOS 数据卡片 + 半场区域块 */
.shot-heatmap-card {
  background: #FFFFFF;
  border: 1rpx solid #E4E7EC;
  border-radius: 26rpx;
  padding: 26rpx;
  margin-bottom: 22rpx;
  box-sizing: border-box;
}
.heatmap-title-row { margin-bottom: 18rpx; }
.heatmap-summary-row {
  display: flex;
  border: 1rpx solid #EEF1F5;
  border-radius: 18rpx;
  overflow: hidden;
  margin-bottom: 22rpx;
  background: #FFFFFF;
}
.heatmap-summary-item {
  flex: 1;
  padding: 18rpx 8rpx 16rpx;
  text-align: center;
  border-right: 1rpx solid #EEF1F5;
  box-sizing: border-box;
}
.heatmap-summary-item:last-child { border-right: none; }
.heatmap-summary-value { color: #111827; font-size: 42rpx; font-weight: 400; line-height: 1.1; letter-spacing: -1rpx; }
.heatmap-summary-label { color: #8A8F98; font-size: 21rpx; font-weight: 800; letter-spacing: .8rpx; margin-top: 6rpx; }
.heatmap-summary-sub { color: #A2A9B3; font-size: 20rpx; margin-top: 3rpx; }
.shot-map-pro {
  position: relative;
  height: 500rpx;
  background: #F3F4F6;
  border: 2rpx solid #DDE2EA;
  border-radius: 18rpx;
  overflow: hidden;
  box-sizing: border-box;
}
.shot-map-pro.compact { height: 470rpx; }
.pro-zone {
  position: absolute;
  z-index: 2;
  border: 2rpx solid rgba(255, 255, 255, .92);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  overflow: hidden;
  padding: 4rpx;
  transition: transform .12s ease, border-color .12s ease;
}
.pro-zone.is-selected {
  z-index: 6;
  border: 4rpx solid #111827;
  transform: scale(1.018);
}
.pro-zone-name { font-size: 20rpx; line-height: 1.08; font-weight: 800; opacity: .92; white-space: nowrap; }
.pro-zone-rate { font-size: 34rpx; line-height: 1.05; font-weight: 800; letter-spacing: -1rpx; margin-top: 5rpx; white-space: nowrap; }
.pro-zone-sub { font-size: 20rpx; line-height: 1.1; font-weight: 700; opacity: .78; margin-top: 5rpx; white-space: nowrap; }
.zone-left-paint { left: 20%; top: 0; width: 20%; height: 31%; }
.zone-rim { left: 40%; top: 0; width: 20%; height: 31%; }
.zone-right-paint { left: 60%; top: 0; width: 20%; height: 31%; }
.zone-left-mid { left: 20%; top: 31%; width: 20%; height: 27%; border-bottom-left-radius: 72rpx; }
.zone-mid { left: 40%; top: 31%; width: 20%; height: 35%; }
.zone-right-mid { left: 60%; top: 31%; width: 20%; height: 27%; border-bottom-right-radius: 72rpx; }
.zone-left-corner { left: 0; top: 54%; width: 20%; height: 46%; border-bottom-left-radius: 18rpx; }
.zone-left-wing { left: 20%; top: 58%; width: 20%; height: 42%; border-top-left-radius: 92rpx; }
.zone-top-three { left: 40%; top: 66%; width: 20%; height: 34%; }
.zone-right-wing { left: 60%; top: 58%; width: 20%; height: 42%; border-top-right-radius: 92rpx; }
.zone-right-corner { left: 80%; top: 54%; width: 20%; height: 46%; border-bottom-right-radius: 18rpx; }
.pro-court-line {
  position: absolute;
  z-index: 4;
  pointer-events: none;
  box-sizing: border-box;
}
.pro-three-arc {
  left: 13%;
  top: 23%;
  width: 74%;
  height: 63%;
  border: 3rpx solid rgba(255, 255, 255, .86);
  border-top: none;
  border-radius: 0 0 420rpx 420rpx;
}
.pro-lane {
  left: 34%;
  top: 0;
  width: 32%;
  height: 31%;
  border-left: 3rpx solid rgba(255,255,255,.82);
  border-right: 3rpx solid rgba(255,255,255,.82);
  border-bottom: 3rpx solid rgba(255,255,255,.82);
}
.pro-backboard {
  left: 43%;
  top: 6%;
  width: 14%;
  height: 0;
  border-top: 4rpx solid rgba(255,255,255,.86);
}
.pro-rim {
  left: 47%;
  top: 8.5%;
  width: 6%;
  height: 6%;
  border: 3rpx solid rgba(255,255,255,.88);
  border-radius: 50%;
}
.heatmap-legend-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  color: #8A8F98;
  font-size: 22rpx;
}
.legend-pair { display: flex; align-items: center; white-space: nowrap; }
.legend-swatch { width: 22rpx; height: 22rpx; border-radius: 6rpx; margin-right: 8rpx; border: 1rpx solid #E4E7EC; box-sizing: border-box; }
.legend-swatch.empty { background: #F2F2F2; }
.legend-gradient { display: flex; align-items: center; flex: 1; margin: 0 18rpx; height: 18rpx; border-radius: 999rpx; overflow: hidden; }
.legend-step { flex: 1; height: 100%; }
.legend-step.s1 { background: #FCE6DA; }
.legend-step.s2 { background: #F8C9AE; }
.legend-step.s3 { background: #F5A06E; }
.legend-step.s4 { background: #FF6A00; }
.legend-labels { display: flex; align-items: center; justify-content: space-between; width: 72rpx; color: #8A8F98; }
.selected-zone-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #FAFBFC;
  border: 1rpx solid #E8EBF0;
}
.selected-zone-name { color: #111827; font-size: 27rpx; font-weight: 800; line-height: 1.25; }
.selected-zone-meta { color: #7A818C; font-size: 22rpx; margin-top: 6rpx; }
.selected-zone-rate { color: #FF5A1F; font-size: 38rpx; font-weight: 800; }
.heatmap-insight {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  background: #FFF7F2;
  border: 1rpx solid #FFD6C8;
  border-radius: 18rpx;
  color: #5B3A2A;
  font-size: 24rpx;
  line-height: 1.55;
}

/* 分析页：Canvas 半场投篮热区图重写版 */
.analysis-page { padding-top: 18rpx; }
.analysis-page .metric-box {
  border-radius: 20rpx;
  border-color: #E5E7EB;
  min-height: 138rpx;
  padding: 22rpx 24rpx;
}
.analysis-page .metric-label { font-size: 24rpx; color: #8A94A6; font-weight: 700; }
.analysis-page .metric-value { font-size: 48rpx; color: #111827; letter-spacing: -1rpx; }
.analysis-page .metric-value.orange { color: #FF5A1F; }
.analysis-page .metric-sub { color: #8A94A6; }
.analysis-metrics { margin-bottom: 8rpx; }
.analysis-metric { min-height: 138rpx; padding: 22rpx 24rpx; }

