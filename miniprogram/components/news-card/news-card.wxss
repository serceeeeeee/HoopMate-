.news-card{display:flex;gap:18rpx;background:#fff;border:1rpx solid #E8EBF0;border-radius:22rpx;padding:20rpx;margin-bottom:18rpx;box-sizing:border-box}.thumb{width:154rpx;height:116rpx;border-radius:16rpx;background:#F2F4F7;overflow:hidden;position:relative;flex:0 0 154rpx}.thumb image{width:100%;height:100%}.thumb.empty:after{content:"NEWS";position:absolute;left:0;right:0;top:0;bottom:0;display:flex;align-items:center;justify-content:center;color:#FF5A1F;font-size:22rpx;font-weight:900;background:#FFF2EC}.news-body{flex:1;min-width:0}.news-title{font-size:29rpx;font-weight:800;color:#1F2933;line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}.news-summary{font-size:23rpx;color:#667085;line-height:1.45;margin-top:8rpx;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}.news-meta{display:flex;justify-content:space-between;gap:12rpx;color:#98A2B3;font-size:20rpx;margin-top:12rpx}
