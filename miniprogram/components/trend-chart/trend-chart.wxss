.trend-scroll{width:100%}.trend-wrap{display:flex;align-items:flex-end;gap:22rpx;min-width:680rpx;height:300rpx;padding:12rpx 8rpx 0;box-sizing:border-box;border-bottom:1rpx solid #E4E7EC;background:linear-gradient(to bottom,#fff 0%,#fff 32%,#F7F8FA 32%,#F7F8FA 33%,#fff 33%,#fff 66%,#F7F8FA 66%,#F7F8FA 67%,#fff 67%)}.trend-item{width:72rpx;height:288rpx;position:relative;text-align:center;flex:0 0 72rpx}.trend-value{height:34rpx;font-size:20rpx;color:#667085;font-weight:700}.trend-stage{position:absolute;left:0;right:0;top:38rpx;bottom:42rpx}.line{position:absolute;bottom:0;left:50%;width:3rpx;background:#FFD5C6;transform:translateX(-50%);border-radius:8rpx}.dot{position:absolute;left:50%;width:18rpx;height:18rpx;border-radius:50%;background:#FF5A1F;border:4rpx solid #fff;box-shadow:0 0 0 2rpx #FF5A1F;transform:translate(-50%,50%)}.bar{position:absolute;bottom:0;left:16rpx;right:16rpx;background:#FF5A1F;border-radius:12rpx 12rpx 0 0}.trend-date{position:absolute;bottom:0;left:0;right:0;color:#8A8F98;font-size:20rpx}.bar .trend-value{color:#1F2933}
