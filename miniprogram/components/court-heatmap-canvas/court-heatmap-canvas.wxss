.court-heatmap-card {
  background: #FFFFFF;
  border: 1rpx solid #E4E7EC;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 22rpx;
  box-sizing: border-box;
}
.court-heatmap-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}
.court-heatmap-copy { flex: 1; min-width: 0; }
.court-heatmap-title {
  color: #111827;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
  letter-spacing: -1rpx;
}
.court-heatmap-subtitle {
  color: #8A94A6;
  font-size: 23rpx;
  line-height: 1.45;
  margin-top: 7rpx;
}
.court-heatmap-tag {
  flex-shrink: 0;
  color: #FF5A1F;
  font-size: 24rpx;
  font-weight: 900;
  padding-top: 4rpx;
}
.court-summary-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border: 1rpx solid #ECEFF3;
  border-radius: 18rpx;
  overflow: hidden;
  background: #FFFFFF;
  margin-bottom: 22rpx;
}
.court-summary-cell {
  padding: 18rpx 6rpx 16rpx;
  text-align: center;
  border-right: 1rpx solid #ECEFF3;
  box-sizing: border-box;
}
.court-summary-cell:last-child { border-right: none; }
.court-summary-name {
  color: #687180;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  margin-bottom: 9rpx;
}
.court-summary-rate {
  color: #111827;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 900;
  letter-spacing: -1rpx;
}
.court-summary-sub {
  color: #8A94A6;
  font-size: 21rpx;
  line-height: 1;
  margin-top: 10rpx;
  font-weight: 700;
}
.court-canvas-wrap {
  width: 100%;
  border: 1rpx solid #E5E7EB;
  border-radius: 18rpx;
  overflow: hidden;
  background: #F7F8FA;
  box-sizing: border-box;
}
.court-heatmap-canvas {
  width: 100%;
  display: block;
  background: #F7F8FA;
}
.court-legend {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
  color: #8A94A6;
  font-size: 21rpx;
  line-height: 1;
}
.court-legend-left {
  display: flex;
  align-items: center;
  white-space: nowrap;
}
.court-legend-empty {
  width: 22rpx;
  height: 22rpx;
  border-radius: 5rpx;
  background: #F1F2F4;
  border: 1rpx solid #E1E5EC;
  margin-right: 8rpx;
  box-sizing: border-box;
}
.court-legend-scale {
  display: flex;
  height: 18rpx;
  border-radius: 999rpx;
  overflow: hidden;
  min-width: 160rpx;
}
.court-legend-scale view { flex: 1; }
.court-legend-scale .l1 { background: #FFE8DC; }
.court-legend-scale .l2 { background: #FFC7AD; }
.court-legend-scale .l3 { background: #FF9B63; }
.court-legend-scale .l4 { background: #FF5A1F; }
.court-legend-text {
  display: flex;
  align-items: center;
  gap: 10rpx;
  white-space: nowrap;
}
.court-selected-panel {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #FAFBFC;
  border: 1rpx solid #E8EBF0;
}
.court-selected-name {
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}
.court-selected-meta {
  color: #8A94A6;
  font-size: 23rpx;
  margin-top: 8rpx;
  line-height: 1.3;
}
.court-selected-rate {
  color: #FF5A1F;
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
  line-height: 1;
  white-space: nowrap;
}
.court-heatmap-insight {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  background: #FFF7F2;
  border: 1rpx solid #FFD8C9;
  border-radius: 18rpx;
  color: #3B424C;
  font-size: 24rpx;
  line-height: 1.55;
  font-weight: 700;
}
.court-heatmap-empty {
  padding: 56rpx 30rpx;
  background: #FAFBFC;
  border: 1rpx dashed #D7DCE4;
  border-radius: 20rpx;
  text-align: center;
}
.court-empty-title { color: #111827; font-size: 30rpx; font-weight: 900; }
.court-empty-desc { color: #8A94A6; font-size: 24rpx; line-height: 1.5; margin: 12rpx 0 24rpx; }
.court-empty-btn { height: 72rpx; line-height: 72rpx; background: #FF5A1F; color: #FFFFFF; border-radius: 999rpx; font-size: 25rpx; font-weight: 900; padding: 0 32rpx; margin: 0 auto; display: inline-block; }
@media (max-width: 360px) {
  .court-heatmap-title { font-size: 31rpx; }
  .court-summary-rate { font-size: 38rpx; }
  .court-legend { font-size: 19rpx; gap: 10rpx; }
  .court-selected-rate { font-size: 40rpx; }
}
