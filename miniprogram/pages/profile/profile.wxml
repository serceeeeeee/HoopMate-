<view class="hm-page with-tab">
  <view class="page-head"><view class="page-kicker">PROFILE</view><view class="page-title">个人档案</view><view class="page-subtitle">维护训练水平、场上位置、每周目标和阶段目标。</view></view>

  <view class="hm-card">
    <view class="row-between"><view><view class="record-title">{{form.nickname}}</view><view class="record-meta">{{form.skill_level}} · {{form.position}}</view></view><view class="metric-box" style="width:170rpx;text-align:center;min-height:120rpx;"><view class="record-rate">{{form.target_accuracy}}%</view><view class="metric-sub">目标命中率</view></view></view>
  </view>

  <view class="hm-card">
    <view class="section-header"><view><view class="section-title">基础信息</view><view class="section-subtitle">保存后首页目标完成度会更新</view></view></view>
    <view class="form-item"><text class="label">昵称</text><input class="input" value="{{form.nickname}}" data-field="nickname" bindinput="onInput" /></view>
    <view class="form-item"><text class="label">训练水平</text><view class="tag-row"><view wx:for="{{levels}}" wx:key="*this" class="tag {{form.skill_level===item?'active':''}}" data-field="skill_level" data-value="{{item}}" bindtap="choose">{{item}}</view></view></view>
    <view class="form-item"><text class="label">场上位置</text><view class="tag-row"><view wx:for="{{positions}}" wx:key="*this" class="tag {{form.position===item?'active':''}}" data-field="position" data-value="{{item}}" bindtap="choose">{{item}}</view></view></view>
    <view class="wrap-row"><view class="col-2"><view class="form-item"><text class="label">每周训练次数</text><input class="input" type="number" value="{{form.weekly_goal_sessions}}" data-field="weekly_goal_sessions" bindinput="onInput" /></view></view><view class="col-2"><view class="form-item"><text class="label">每周训练分钟</text><input class="input" type="number" value="{{form.weekly_goal_minutes}}" data-field="weekly_goal_minutes" bindinput="onInput" /></view></view></view>
    <view class="form-item"><text class="label">目标命中率</text><input class="input" type="number" value="{{form.target_accuracy}}" data-field="target_accuracy" bindinput="onInput" /></view>
    <view class="form-item"><text class="label">阶段目标</text><textarea class="textarea" value="{{form.stage_goal}}" data-field="stage_goal" bindinput="onInput" /></view>
    <button class="primary-btn" bindtap="save">保存档案</button>
  </view>

  <view class="hm-card">
    <view class="section-header"><view><view class="section-title">更多入口</view><view class="section-subtitle">项目展示与扩展页面</view></view></view>
    <view class="quick-wrap"><view class="quick-item" bindtap="goGames"><view class="quick-inner"><view class="quick-title">赛事数据</view><view class="quick-desc">赛程与比分</view></view></view><view class="quick-item" bindtap="goPlayers"><view class="quick-inner"><view class="quick-title">球员数据</view><view class="quick-desc">合成数据展示</view></view></view><view class="quick-item" bindtap="goAdvice"><view class="quick-inner"><view class="quick-title">训练建议</view><view class="quick-desc">下一周计划</view></view></view><view class="quick-item" bindtap="goAbout"><view class="quick-inner"><view class="quick-title">项目说明</view><view class="quick-desc">技术方案</view></view></view></view>
  </view>
</view>
