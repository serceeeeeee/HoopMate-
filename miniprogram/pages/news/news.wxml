<view class="hm-page with-tab">
  <view class="page-head"><view class="page-kicker">BASKETBALL NEWS</view><view class="page-title">篮球新闻</view><view class="page-subtitle">默认使用本地 mock 新闻，后续可接入后端代理 API。</view></view>
  <view class="hm-card">
    <view class="tag-row"><view wx:for="{{categories}}" wx:key="*this" class="tag {{activeCategory===item?'active':''}}" data-value="{{item}}" bindtap="chooseCategory">{{item}}</view></view>
  </view>
  <view wx:for="{{list}}" wx:key="id" class="hm-card" bindtap="goDetail" data-id="{{item.id}}">
    <view class="row-between"><view class="tag active">{{item.category}}</view><view class="record-meta">{{item.publishedAt}}</view></view>
    <view class="record-title" style="margin-top:14rpx;">{{item.title}}</view>
    <view class="record-meta">{{item.source}}</view>
    <view class="page-subtitle">{{item.summary}}</view>
  </view>
  <view class="empty-state" wx:if="{{!list.length}}"><view class="empty-title">暂无新闻</view><view class="empty-desc">可以切换分类或下拉刷新。</view><button class="secondary-btn" bindtap="load">重试</button></view>
</view>
