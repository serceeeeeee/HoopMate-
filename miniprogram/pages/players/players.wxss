.table-scroll { width: 100%; }
.player-table { min-width: 980rpx; }
.table-row { display: grid; grid-template-columns: 220rpx 100rpx 120rpx 120rpx 120rpx 140rpx; gap: 12rpx; align-items: center; padding: 18rpx 0; border-bottom: 1rpx solid rgba(255,255,255,.07); color: #CBD5E1; font-size: 24rpx; }
.table-head { color: #FDBA74; font-weight: 900; }
.bar-row { display: grid; grid-template-columns: 190rpx 1fr 76rpx; gap: 14rpx; align-items: center; margin-bottom: 18rpx; }
.bar-name { color: #CBD5E1; font-size: 24rpx; }
.bar-track { height: 24rpx; background: rgba(30,41,59,.95); border-radius: 999rpx; overflow: hidden; }
.bar-fill { height: 100%; background: linear-gradient(90deg, #22D3EE, #FF7A1A); border-radius: 999rpx; }
.bar-num { text-align: right; color: #F8FAFC; font-weight: 850; font-size: 24rpx; }
.scatter-box { position: relative; height: 420rpx; background: linear-gradient(180deg, rgba(15,23,42,.9), rgba(15,23,42,.55)); border: 1rpx solid rgba(255,255,255,.08); border-radius: 26rpx; margin-bottom: 18rpx; overflow: hidden; }
.scatter-box::before { content: ""; position: absolute; left: 52rpx; right: 24rpx; bottom: 52rpx; top: 24rpx; border-left: 2rpx solid rgba(255,255,255,.18); border-bottom: 2rpx solid rgba(255,255,255,.18); }
.scatter-dot { position: absolute; border-radius: 50%; text-align: center; background: rgba(255,122,26,.78); color: #fff; font-size: 18rpx; font-weight: 900; box-shadow: 0 0 22rpx rgba(255,122,26,.36); transform: translate(-50%, 50%); }
.axis-label { position: absolute; color: #64748B; font-size: 22rpx; }
.x-label { right: 30rpx; bottom: 18rpx; }
.y-label { left: 16rpx; top: 18rpx; }
